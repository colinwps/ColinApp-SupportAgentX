# ============================================================
# 模型提供商选择（anthropic / openai / deepseek / qwen / ollama）
# ============================================================
LLM_PROVIDER=anthropic

# ============================================================
# 各厂商 API Key（按需填写对应厂商即可）
# ============================================================
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
DASHSCOPE_API_KEY=sk-...        # 阿里云通义千问

# ============================================================
# 各厂商模型名称（可按需自定义）
# ============================================================
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
DEEPSEEK_MODEL=deepseek-chat
QWEN_MODEL=qwen-max
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# 知识库配置
# ============================================================
KNOWLEDGE_BASE_DIR=./knowledge_base/docs
CHROMA_PERSIST_DIR=./knowledge_base/.chroma_db
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5   # 中文友好，可换 bge-m3

# ============================================================
# Agent 行为配置
# ============================================================
MAX_ITERATIONS=10          # 最大推理轮次
RETRIEVAL_TOP_K=3          # RAG 返回文档数
CONFIDENCE_THRESHOLD=0.6   # 低于此分数转人工
